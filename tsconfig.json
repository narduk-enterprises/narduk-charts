{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@narduk-enterprises/narduk-charts": ["./src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.vue",
    "playground/**/*.ts",
    "playground/**/*.d.ts",
    "playground/**/*.vue",
    "site/**/*.ts",
    "site/**/*.d.ts",
    "site/**/*.vue"
  ],
  "exclude": ["node_modules", "dist", "playground/vite.config.ts", "site/vite.config.ts", "histoire.config.ts"]
}
