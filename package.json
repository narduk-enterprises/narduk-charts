{
  "name": "narduk-charts",
  "version": "1.0.0",
  "description": "Vue 3 SVG charting library for dashboards and trading-grade market UIs (TypeScript, themable, accessible)",
  "type": "module",
  "main": "./dist/narduk-charts.umd.cjs",
  "module": "./dist/narduk-charts.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/narduk-charts.js",
      "require": "./dist/narduk-charts.umd.cjs"
    },
    "./line": {
      "types": "./dist/index.d.ts",
      "import": "./dist/line.js"
    },
    "./bar": {
      "types": "./dist/index.d.ts",
      "import": "./dist/bar.js"
    },
    "./pie": {
      "types": "./dist/index.d.ts",
      "import": "./dist/pie.js"
    },
    "./candle": {
      "types": "./dist/index.d.ts",
      "import": "./dist/candle.js"
    },
    "./studies": {
      "types": "./dist/index.d.ts",
      "import": "./dist/studies.js"
    },
    "./style.css": "./dist/narduk-charts.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config site/vite.config.ts",
    "dev:playground": "vite --config playground/vite.config.ts",
    "dev:site": "vite --config site/vite.config.ts",
    "build:site": "vite build --config site/vite.config.ts",
    "build": "vue-tsc --noEmit && vite build && NC_ENTRY=line vite build --config vite.entries.config.ts && NC_ENTRY=bar vite build --config vite.entries.config.ts && NC_ENTRY=pie vite build --config vite.entries.config.ts && NC_ENTRY=candle vite build --config vite.entries.config.ts && NC_ENTRY=studies vite build --config vite.entries.config.ts && rm -f dist/entry-*.css",
    "build:only": "vite build && NC_ENTRY=line vite build --config vite.entries.config.ts && NC_ENTRY=bar vite build --config vite.entries.config.ts && NC_ENTRY=pie vite build --config vite.entries.config.ts && NC_ENTRY=candle vite build --config vite.entries.config.ts && NC_ENTRY=studies vite build --config vite.entries.config.ts",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "story:dev": "histoire dev",
    "story:build": "histoire build",
    "test:e2e": "PLAYWRIGHT_TARGET=components playwright test --project=chromium",
    "test:e2e:update": "PLAYWRIGHT_TARGET=components playwright test --project=chromium --update-snapshots",
    "test:e2e:ui": "PLAYWRIGHT_TARGET=site playwright test --project=ui-quality",
    "test:e2e:ui:analyze": "node tools/playwright/analyze-ui-quality.mjs output/playwright/ui-quality",
    "size": "size-limit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@histoire/plugin-vue": "^0.17.17",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^12.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^5.2.0",
    "histoire": "^0.17.17",
    "sharp": "^0.34.5",
    "size-limit": "^12.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.6.4",
    "vue-tsc": "^2.2.0"
  },
  "keywords": [
    "vue",
    "vue3",
    "chart",
    "charts",
    "svg",
    "line-chart",
    "bar-chart",
    "pie-chart",
    "donut-chart",
    "data-visualization",
    "typescript",
    "composition-api",
    "tailwindcss"
  ],
  "license": "MIT",
  "author": "narduk",
  "repository": {
    "type": "git",
    "url": "https://github.com/narduk-enterprises/narduk-charts"
  }
}
